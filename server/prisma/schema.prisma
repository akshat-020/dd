generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres in both dev and production (dev via a local instance or the
  // devcontainer's, production via Neon/Render/etc.) — same engine
  // everywhere avoids the class of bug where something behaves differently
  // only in production because dev was running against SQLite.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role is a plain validated String (see src/lib/roles.ts), not a native
// Postgres enum — adding a role later is then a code change + no-downtime
// deploy instead of a blocking ALTER TYPE migration. Valid values: OWNER |
// ACCOUNTANT | SALES | WAREHOUSE
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Composable add-on permission: lets a Sales-staff account also perform
  // scan-based putaway/pick actions without becoming a Warehouse role (and
  // without inheriting Warehouse's task-scoped visibility restriction).
  // Meaningless for other roles — Owner/Warehouse always have scan access,
  // Accountant never does, regardless of this flag. Grantable by Owner only.
  canScanPutaway Boolean @default(false)

  // Composable permission: lets a Sales-staff account log inward stock
  // entries (SKU + qty + supplier ref + date, triggers label printing).
  // Defaults to true for Sales (it's part of their normal baseline, not an
  // opt-in add-on like canScanPutaway) but stays a per-user override so an
  // Owner can revoke it for a specific person. Meaningless for other
  // roles — Owner always has it, Accountant/Warehouse never do, regardless
  // of this flag. The cost/price side of a purchase (PurchaseCostReference)
  // is a separate, Owner+Accountant-only action — never gated by this flag.
  canLogInwardEntry Boolean @default(true)

  // Optional TOTP-based 2FA. Recommended (not forced) for Owner/Accountant
  // since those roles reach pricing/cost data — a compromised password
  // alone shouldn't be enough. totpSecret is only set once enrollment is
  // completed (see routes/auth.ts); totpEnabled gates whether login
  // actually requires the second factor.
  totpSecret  String?
  totpEnabled Boolean @default(false)

  ordersCreated           Order[]                 @relation("OrderCreatedBy")
  stockMovements          StockMovement[]
  pickListItemsDone       PickListItem[]
  invoiceRefsCreated      InvoiceReference[]
  purchaseCostRefsCreated PurchaseCostReference[]
  auditLogs               AuditLog[]
  sessions                Session[]
  putBacksConfirmed       PutBackTask[]
  proformaInvoicesCreated ProformaInvoice[]
}

// Server-side session record backing each JWT (the token embeds this row's
// id as `sid`). This is what makes two things possible that a pure
// stateless JWT can't do on its own: inactivity-based expiry (checked and
// refreshed on every request) and immediate remote revocation — an Owner
// can invalidate a lost phone's session right away instead of waiting up
// to the JWT's absolute expiry.
model Session {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
}

model Sku {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  unit             String // base unit — all stock quantities/movements/availability are tracked in this
  category         String?
  reorderThreshold Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  // Optional per-SKU compound unit (e.g. Box = 10 pcs for this SKU, 12 for
  // another) — never a global constant. Both null means this SKU only ever
  // has one unit. Changing altUnitFactor on a SKU that already has stock or
  // open orders only applies going forward (see routes/skus.ts) — existing
  // OrderLine/InvoiceReferenceLine rows freeze the factor that was in effect
  // when they were entered, so a later change never reinterprets history.
  altUnitName   String?
  altUnitFactor Int?

  batches              SkuBatch[]
  stockItems           StockItem[]
  stockMovements       StockMovement[]
  orderLines           OrderLine[]
  pickListItems        PickListItem[]
  invoiceRefLines      InvoiceReferenceLine[]
  putBackTasks         PutBackTask[]
  proformaInvoiceLines ProformaInvoiceLine[]
}

// A labeled batch/lot of a SKU, created at purchase or production receipt —
// this is the "inward entry" (SKU + qty + supplier/batch ref + date). The
// QR label printed on the physical goods encodes skuId+batchCode+date.
// What it cost (if a purchase) is recorded separately, later, as one or
// more PurchaseCostReferences — same physical-event/cost-event split as
// Order vs. InvoiceReference on the sales side.
model SkuBatch {
  id               String   @id @default(cuid())
  sku              Sku      @relation(fields: [skuId], references: [id])
  skuId            String
  batchCode        String
  sourceType       String // PURCHASE | PRODUCTION
  receivedQuantity Int? // declared at inward-entry time; null for pre-existing/legacy batches
  supplierRef      String? // supplier's own PO/invoice/delivery number, distinct from our batchCode
  receivedDate     DateTime @default(now())
  note             String?
  createdAt        DateTime @default(now())

  stockItems     StockItem[]
  stockMovements StockMovement[]
  costReferences PurchaseCostReference[]

  @@unique([skuId, batchCode])
}

// Zone > Rack > Shelf/Bin hierarchy. `code` is the human-readable string
// encoded in the printed location QR label, e.g. "A-03-02".
model Location {
  id     String  @id @default(cuid())
  code   String  @unique
  zone   String
  rack   String
  bin    String?
  active Boolean @default(true)

  stockItems     StockItem[]
  stockMovements StockMovement[]
  pickListItems  PickListItem[]
  putBacksFrom   PutBackTask[]   @relation("PutBackFromLocation")
  putBacksTo     PutBackTask[]   @relation("PutBackToLocation")
}

// Live quantity of a SKU (optionally a specific batch) at a specific location.
model StockItem {
  id         String    @id @default(cuid())
  sku        Sku       @relation(fields: [skuId], references: [id])
  skuId      String
  location   Location  @relation(fields: [locationId], references: [id])
  locationId String
  batch      SkuBatch? @relation(fields: [batchId], references: [id])
  batchId    String?
  quantity   Int       @default(0)

  @@unique([skuId, locationId, batchId])
}

// Append-only ledger of every stock change. This is the audit trail for
// pain point #6 (who moved what, when).
model StockMovement {
  id                String    @id @default(cuid())
  sku               Sku       @relation(fields: [skuId], references: [id])
  skuId             String
  location          Location  @relation(fields: [locationId], references: [id])
  locationId        String
  batch             SkuBatch? @relation(fields: [batchId], references: [id])
  batchId           String?
  quantity          Int // signed delta: positive = in, negative = out
  type              String // INBOUND | OUTBOUND | TRANSFER_IN | TRANSFER_OUT | ADJUSTMENT
  reason            String?
  refOrderId        String?
  refInvoiceRefId   String?
  relatedMovementId String? // links the two legs of a TRANSFER
  user              User      @relation(fields: [userId], references: [id])
  userId            String
  createdAt         DateTime  @default(now())
}

model Order {
  id                  String    @id @default(cuid())
  orderNumber         String    @unique
  buyerName           String
  buyerContact        String?
  status              String    @default("DRAFT") // DRAFT | FINALIZED | LOADED | INVOICED | CANCELLED
  vehicleCapacityNote String?
  createdBy           User      @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdById         String
  createdAt           DateTime  @default(now())
  finalizedAt         DateTime?
  loadedAt            DateTime?

  lines             OrderLine[]
  pickListItems     PickListItem[]
  invoiceReferences InvoiceReference[]
  putBackTasks      PutBackTask[]
  proformaInvoices  ProformaInvoice[]
}

model OrderLine {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id])
  orderId      String
  sku          Sku     @relation(fields: [skuId], references: [id])
  skuId        String
  qtyRequested Int // always in the SKU's base unit — canonical, used for all stock math
  qtyFinalized Int? // always in the SKU's base unit — canonical, used for all stock math
  qtyPicked    Int     @default(0)
  notes        String?

  // How Requested/Final Qty were actually entered — unit name, the quantity
  // in that unit, and the conversion factor in effect at entry time (frozen,
  // so a later change to the SKU's altUnitFactor never reinterprets a
  // historical line). Null on both requested* and final* fields means "this
  // row predates multi-unit support" — display code falls back to
  // qty(Requested|Finalized) + sku.unit directly in that case.
  requestedUnit    String?
  requestedUnitQty Int?
  requestedFactor  Int?
  finalUnit        String?
  finalUnitQty     Int?
  finalFactor      Int?

  // Price kept in a separate 1:1 table so it can be omitted entirely from
  // Prisma `select`/`include` for non-privileged roles (structural
  // separation, not just a UI hide).
  price OrderLinePrice?

  pickListItems PickListItem[]
  putBackTasks  PutBackTask[]
}

model OrderLinePrice {
  id          String    @id @default(cuid())
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id])
  orderLineId String    @unique
  // Encrypted at rest (AES-256-GCM, see src/lib/crypto.ts) — stored as an
  // opaque ciphertext string, never a plain numeric column. Encrypted/
  // decrypted only in the request handler for a role that's already
  // allowed to see it; it's never queried or aggregated at the SQL level.
  unitPrice   String
  updatedAt   DateTime  @updatedAt
  updatedById String
}

// One row per (order, location, sku, batch) pick task, generated on finalize.
model PickListItem {
  id         String    @id @default(cuid())
  order      Order     @relation(fields: [orderId], references: [id])
  orderId    String
  sku        Sku       @relation(fields: [skuId], references: [id])
  skuId      String
  location   Location  @relation(fields: [locationId], references: [id])
  locationId String
  batchId    String?
  sequence   Int
  qtyToPick  Int
  qtyPicked  Int       @default(0)
  status     String    @default("PENDING") // PENDING | LOCATION_CONFIRMED | SKU_CONFIRMED | PICKED
  pickedBy   User?     @relation(fields: [pickedById], references: [id])
  pickedById String?
  pickedAt   DateTime?

  // Which order line this allocation belongs to — required for every row
  // created going forward. Nullable only because rows created before this
  // field existed can't be disambiguated when the same SKU appeared as more
  // than one line on the same order (see the multi-unit-addendum follow-up
  // bug report: without this, reconcileOrderLineAllocation and the pick-
  // confirm handler had to guess which line an allocation belonged to by
  // (orderId, skuId) alone, which silently mis-allocated stock whenever a
  // SKU appeared on two lines of the same order).
  orderLine   OrderLine? @relation(fields: [orderLineId], references: [id])
  orderLineId String?

  // Set when this row exists because a previous pick came up short (picked
  // less than qtyToPick) — an auto-generated follow-up task for the
  // remainder, rather than something finalize itself allocated. `note`
  // carries the human-readable reason ("Shortfall follow-up: picked 9 of
  // 10 at <location>"); `isShortfallFollowup` is what the Dashboard's
  // "Shortfalls needing attention" list actually queries on.
  isShortfallFollowup Boolean @default(false)
  note                String?

  // How the picker actually expressed the picked quantity (e.g. "2 Box"),
  // for display/audit only — qtyPicked above stays the base-unit (Pcs)
  // canonical value all stock math uses. boxesOpened records a deliberate
  // box-break to fulfill a partial-box quantity (e.g. needed 25 pcs from
  // boxes of 10 -> opened 1 box) — purely an audit/traceability record,
  // since breaking a box doesn't change the total Pcs count at this
  // location and so has no effect on the compound-breakdown math.
  pickedUnit    String?
  pickedUnitQty Int?
  boxesOpened   Int     @default(0)

  putBackTasks PutBackTask[]
}

model InvoiceReference {
  id                 String   @id @default(cuid())
  tallyInvoiceNumber String   @unique
  order              Order    @relation(fields: [orderId], references: [id])
  orderId            String
  date               DateTime @default(now())
  status             String   @default("ACTIVE") // ACTIVE | CANCELLED | ADJUSTED
  createdBy          User     @relation(fields: [createdById], references: [id])
  createdById        String
  createdAt          DateTime @default(now())

  lines InvoiceReferenceLine[]
}

model InvoiceReferenceLine {
  id                 String           @id @default(cuid())
  invoiceReference   InvoiceReference @relation(fields: [invoiceReferenceId], references: [id])
  invoiceReferenceId String
  sku                Sku              @relation(fields: [skuId], references: [id])
  skuId              String
  qty                Int // in `unit` if set, else the SKU's base unit — this is what was billed
  // Encrypted at rest (AES-256-GCM) — see OrderLinePrice.unitPrice comment.
  // Price applies per 1 of `unit` — never auto-derived from a base-unit
  // price × factor, since box/bulk pricing commonly carries its own margin.
  price              String

  // Null means base unit (pre-multi-unit rows, or billed in the SKU's base
  // unit). unitFactor is frozen at entry time, same reasoning as
  // OrderLine.requestedFactor. qtyBaseUnits is the Pcs-equivalent, used for
  // stock-reversal math on cancel/adjust (which operates in base units).
  unit         String?
  unitFactor   Int?
  qtyBaseUnits Int?
}

// The cost/financial counterpart to a SkuBatch inward entry — mirrors
// InvoiceReference on the sales side. Logged separately from (and any time
// after) the inward entry itself, and restricted to Owner+Accountant only,
// so floor-level receiving staff never see or enter what goods cost.
model PurchaseCostReference {
  id          String   @id @default(cuid())
  batch       SkuBatch @relation(fields: [batchId], references: [id])
  batchId     String
  quantity    Int
  // Encrypted at rest (AES-256-GCM) — see OrderLinePrice.unitPrice comment.
  unitCost    String
  supplierRef String?
  note        String?
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
}

// Append-only by construction — no route anywhere updates or deletes an
// AuditLog row. hash/previousHash form a tamper-evident chain (each row's
// hash covers its own content + the prior row's hash) so that even a direct
// database edit changes the chain and can be detected by recomputing it,
// not just relying on "no API exists to do it."
model AuditLog {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  action       String
  entityType   String
  entityId     String
  before       String?
  after        String?
  createdAt    DateTime @default(now())
  previousHash String?
  hash         String
}

// Round-4 operational-flow addendum: a Final Qty reduction after some (or
// all) of that line's quantity was already physically picked doesn't just
// erase the excess — it has to come back to a shelf. This is that pending
// return task, created by reconcileOrderLineAllocation the moment a
// decrease can't be fully absorbed by not-yet-picked allocation alone (see
// stock.ts). Quantity here is deliberately NOT reflected in any StockItem
// row until confirmed — it's "picked, not yet returned," visible via this
// row (and the order line's derived pendingPutBackQty) rather than either
// silently vanishing from the count or silently reappearing as available
// stock before it's physically back on a shelf.
model PutBackTask {
  id                   String       @id @default(cuid())
  order                Order        @relation(fields: [orderId], references: [id])
  orderId              String
  orderLine            OrderLine    @relation(fields: [orderLineId], references: [id])
  orderLineId          String
  sku                  Sku          @relation(fields: [skuId], references: [id])
  skuId                String
  // The specific PICKED PickListItem this quantity is being clawed back
  // from — confirming this task decrements that row's qtyPicked (and the
  // order line's), not just any row for the same line.
  sourcePickListItem   PickListItem @relation(fields: [sourcePickListItemId], references: [id])
  sourcePickListItemId String
  fromLocation         Location     @relation("PutBackFromLocation", fields: [fromLocationId], references: [id])
  fromLocationId       String
  batchId              String?
  quantity             Int
  status               String       @default("PENDING") // PENDING | CONFIRMED
  toLocation           Location?    @relation("PutBackToLocation", fields: [toLocationId], references: [id])
  toLocationId         String?
  confirmedBy          User?        @relation(fields: [confirmedById], references: [id])
  confirmedById        String?
  confirmedAt          DateTime?
  createdAt            DateTime     @default(now())
}

// Company bank details shown on a Proforma Invoice for advance-payment
// collection. Singleton row (id "singleton") — Owner-editable, not a
// per-order or per-user setting.
model CompanySettings {
  id                String   @id @default("singleton")
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  // SINGLE = one label per "page" (thermal/continuous-feed printer). GRID =
  // several labels laid out on a standard sheet (regular printer + adhesive
  // label sheets). Set once here rather than hard-coded to one printer —
  // see the label-printing addendum, item 6.
  labelPrintFormat  String   @default("SINGLE")
  updatedAt         DateTime @updatedAt
  updatedById       String?
}

// A Proforma Invoice — a preliminary, non-statutory document sent to the
// buyer before the actual Tally tax invoice (InvoiceReference). Its own
// numbering series (PI-YYYY-NNNN) so it can never collide with or be
// mistaken for a real invoice number. Reissuing (e.g. after a Final Qty
// change) creates a new row with an incremented version and marks the
// previous one SUPERSEDED, rather than mutating history — so it's always
// clear which PI is current and what an earlier version said.
model ProformaInvoice {
  id          String   @id @default(cuid())
  piNumber    String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  version     Int      @default(1)
  status      String   @default("ACTIVE") // ACTIVE | SUPERSEDED
  issueDate   DateTime @default(now())
  validUntil  DateTime
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  lines ProformaInvoiceLine[]
}

model ProformaInvoiceLine {
  id                String          @id @default(cuid())
  proformaInvoice   ProformaInvoice @relation(fields: [proformaInvoiceId], references: [id])
  proformaInvoiceId String
  sku               Sku             @relation(fields: [skuId], references: [id])
  skuId             String
  qty               Int // in `unit`
  unit              String
  // Encrypted at rest (AES-256-GCM) — see OrderLinePrice.unitPrice comment.
  unitPrice         String
}
