# Postgres in both dev and production. The devcontainer provisions a local
# instance with this exact URL automatically (see .devcontainer/devcontainer.json).
# Running outside the devcontainer: point this at your own local Postgres,
# or at a free Neon/Render database for a quick start.
DATABASE_URL="postgresql://postgres:localdev@localhost:5432/oms_erp_dev"
JWT_SECRET="change-me-in-production"
PORT=4000

# Comma-separated list of origins allowed to call the API (CORS). The Vite
# dev server and any deployed web app origin must be listed here.
WEB_ORIGIN="http://localhost:5173"

# 32-byte key (as base64 or hex) used to encrypt price/cost fields at rest
# (OrderLinePrice.unitPrice, InvoiceReferenceLine.price,
# PurchaseCostReference.unitCost). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key makes existing encrypted price/cost data unrecoverable —
# back it up separately from the database itself.
FIELD_ENCRYPTION_KEY="change-me-generate-a-real-32-byte-key"

# Set to "true" once TLS is terminated in front of this app (reverse proxy,
# load balancer, or platform-managed HTTPS) so it can reject/redirect any
# request that arrives over plain HTTP.
REQUIRE_HTTPS="false"

# Minutes of inactivity before a login session auto-expires.
SESSION_INACTIVITY_MINUTES=30

# Required to call POST /api/auth/bootstrap, which creates the very first
# (Owner) account in an otherwise-empty database — see README.md's
# "Deploying" section. Not needed for local dev (npm run setup seeds demo
# accounts directly). Generate a real value for production with:
#   openssl rand -hex 16
BOOTSTRAP_SECRET="local-dev-not-used"
